{
  "name": "fossa-docs-screenshot-generator",
  "version": "0.2.1",
  "description": "Generate FOSSA docs-ready screenshots from source images.",
  "license": "MIT",
  "keywords": [
    "screenshot",
    "cli",
    "fossa",
    "docs",
    "image"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/himynameisdave/fossa-docs-screenshot-generator.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/himynameisdave/fossa-docs-screenshot-generator#readme",
  "bugs": {
    "url": "https://github.com/himynameisdave/fossa-docs-screenshot-generator/issues"
  },
  "type": "module",
  "bin": {
    "fossa-docs-screenshot": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --target=node --outfile=dist/cli.js --packages=external",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "bun src/cli.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "sharp": "^0.34.0"
  },
  "engines": {
    "node": ">=20"
  }
}
